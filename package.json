{
  "name": "wakfu-craft",
  "version": "0.3.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "electron:compile": "tsc -p tsconfig.electron.json && node -e \"const{cpSync}=require('fs');cpSync('electron/database/migrations','dist-electron/database/migrations',{recursive:true,force:true})\"",
    "electron:dev": "concurrently --kill-others \"ng serve\" \"wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "ng build --base-href ./ && npm run electron:compile && electron-builder",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "ng test",
    "lint": "eslint src electron",
    "lint:fix": "eslint src electron --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"electron/**/*.ts\""
  },
  "build": {
    "appId": "com.wakfu.craft",
    "productName": "Wakfu Craft",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "node-fetch": "^3.3.2",
    "rxjs": "~7.8.0",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.5"
  }
}
